# ================================================================
# FANCY NETWORK STORE — .env.local
# Rename file ini → .env.local
# JANGAN commit .env.local ke Git!
# ================================================================

# ── Website URL ─────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://208.84.103.117:25580
# Setelah domain aktif:
# NEXT_PUBLIC_BASE_URL=https://fancynet.my.id

# ── Data folder (opsional, default: ./data) ──────────────────────
# Untuk VPS, bisa set ke path absolut agar data tidak hilang saat deploy
# DATA_DIR=/var/data/fancynetwork

# ── Plugin ShadowynAPI HTTP (port 12025) ─────────────────────────
# URL HTTP server plugin di server Minecraft
PLUGIN_HTTP_URL=http://IP_SERVER_MINECRAFT:12025
# Server key — harus sama dengan config.yml plugin
PLUGIN_SERVER_KEY=isi-server-key-dari-config-plugin

# ── Midtrans Payment Gateway ─────────────────────────────────────
# Daftar di: https://dashboard.midtrans.com
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MIDTRANS_ENV=sandbox
# Ganti ke: production (saat live)
MIDTRANS_ENV=sandbox

# ── JWT Secret ───────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=ganti-dengan-random-hex-64-karakter

# ── Admin Panel ──────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=GantiPasswordIni123!

# ── Status Server Minecraft ───────────────────────────────────────
# API publik untuk cek status server
MC_STATUS_URL=https://api.mcsrvstat.us/2/fancynet.my.id

# ── Discord Webhooks (2 TERPISAH) ────────────────────────────────
# 1. Log transaksi (sukses/gagal/pending)
DISCORD_WEBHOOK_TX=https://discord.com/api/webhooks/xxx/yyy
# 2. Notifikasi tiket support masuk
DISCORD_WEBHOOK_REPORT=https://discord.com/api/webhooks/xxx/zzz
